BootStrap: docker
From: ubuntu:20.04


%startscript

%runscript
  asperascp


%files
ibm-aspera-desktopclient-3.9.6.176292-linux-64.deb /opt

%environment

%post
  apt update -y

  export DEBIAN_FRONTEND=noninteractive
  ln -fs /usr/share/zoneinfo/Europe/Berlin /etc/localtime
  apt-get install -y tzdata
  dpkg-reconfigure --frontend noninteractive tzdata

  apt install -y libxext6 libxrender1 libfreetype6-dev libxtst-dev nautilus
  dpkg -i /opt/ibm-aspera-desktopclient-3.9.6.176292-linux-64.deb
